# PropControl Environment Example

# Copy this file to .env and adjust values for your installation.

########################
# Core App Settings
########################

# Node environment for the app (development | production)
APP_ENV=production

# Default locale for the UI (German)
APP_LOCALE=de-DE

# Public app URL (used for links, emails later)
APP_BASE_URL=http://localhost:3000

########################
# Supabase Core Settings
########################

# Supabase project identifier (can be arbitrary for self-hosted setups)
SUPABASE_PROJECT_ID=propcontrol

# Database connection
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_USER=postgres
POSTGRES_DB=postgres

# JWT secret used by Supabase Auth
JWT_SECRET=change_me_jwt_secret

# Supabase API keys (self-hosted)
SUPABASE_ANON_KEY=change_me_anon_key
SUPABASE_SERVICE_ROLE_KEY=change_me_service_role_key

# Supabase URLs (internal and external)
SUPABASE_URL=http://supabase-api:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

########################
# App ↔ Supabase Integration
########################

# These will be used by the frontend to talk to Supabase (later slices)
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_PUBLIC_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

########################
# Miscellaneous
########################

# Timezone for logs and scheduling (application uses UTC internally)
APP_TIMEZONE=Europe/Berlin
